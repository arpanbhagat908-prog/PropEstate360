# ─── SERVER ────────────────────────────────────────────────────────────
PORT=3001

# ─── JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_xxxxxxx_string_in_prodxxxxxxxxx

# ─── ADMIN (only Arpan) ────────────────────────────────────────────────
ADMIN_NAME=Arpan
ADMIN_EMAIL=arpan@propestate360.com
ADMIN_PASSWORD=Admin@Secure123
ADMIN_PHONE=xxxxxxxx

# ─── EMAIL (Gmail SMTP for real OTP) ──────────────────────────────────
# Steps:
#  1. Go to your Gmail → Settings → Security → Enable 2-Step Verification
#  2. Search "App passwords" → Create one for "Mail"
#  3. Paste the 16-character code below (remove spaces)
GMAIL_USER=xxxxxxxxx@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxx

# ─── DATABASE ──────────────────────────────────────────────────────────
DB_PATH=./data/propestate360.db

# ─── FRONTEND URL (for CORS) ──────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
